{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf :*)",
      "Bash(git push --force :*)",
      "Bash(git reset --hard :*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/commit-discipline-check.sh\""
          }
        ]
      }
    ]
  }
}
